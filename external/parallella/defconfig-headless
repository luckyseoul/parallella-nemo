# Parallella Nemo - Base Configuration (headless)
BR2_arm=y
BR2_cortex_a9=y

BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_TOOLCHAIN_BUILDROOT_WCHAR=y
BR2_TOOLCHAIN_BUILDROOT_THREADS_PTHREADS=y

BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_DEFCONFIG="xilinx_zynq"

BR2_SYSTEM_DHCP="eth0"
BR2_TARGET_GENERIC_HOSTNAME="parallella"

BR2_PACKAGE_DIALOG=y
BR2_PACKAGE_NCURSES=y
BR2_PACKAGE_WPA_SUPPLICANT=y
BR2_PACKAGE_SYSTEMD=y

# Epiphany SDK
BR2_PACKAGE_HOST_EPIPHANY_SDK=y

# Packages (Python3-dependent packages disabled until toolchain fixed)
BR2_PACKAGE_ETOP=y
BR2_PACKAGE_FIRSTBOOT=y
BR2_PACKAGE_EXPLORER=y
BR2_PACKAGE_FPGA_LOADER=y

# Useful tools
BR2_PACKAGE_HTOP=y
BR2_PACKAGE_DROPBEAR=y
BR2_PACKAGE_GIT=y